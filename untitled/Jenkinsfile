pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
            dir('untitled'){
                sh 'chmod +x gradlew'
                sh './gradlew build'
                }
            }
        }

        stage('Test') {
            steps {
             dir('untitled'){
                sh './gradlew test'
                }
            }
        }
    }

    post {
        always {
            junit '**/build/test-results/test/*.xml'
        }
        success {
            echo 'Build and test succeeded!'
            sh 'echo "Build Success - $(date)" > build-result.txt'
            archiveArtifacts artifacts: 'build-result.txt'
        }
        failure {
            echo 'Build or test failed!'
        }
    }
}